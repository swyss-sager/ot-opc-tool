{
  "analyzer": {
    "input_files": [
      {
        "path": "data/merged/merged_output_2026-03-03T13_32_23.42.csv",
        "format": "csv"
      }
    ],
    "output_dir": "data/analyzer/_output",
    "plots_dir":  "data/analyzer/analyzer_plots",
    "write_report_json": true,

    "run_descriptive":     true,
    "run_exploratory":     true,
    "run_diagnostic":      true,
    "run_inferential":     true,
    "run_predictive":      true,
    "run_prescriptive":    true,
    "run_patterns":        true,
    "run_distribution":    true,
    "run_timeseries":      true,
    "run_anomaly_ext":     true,
    "run_correlation_adv": true,
    "run_quality":         true,
    "run_viz_extended":    true,
    "run_regression":      true,

    "analyses": {
      "descriptive": {
        "percentiles": [10, 25, 50, 75, 90, 95, 99]
      },
      "exploratory": {
        "plot_correlations":   true,
        "plot_distributions":  true,
        "handle_missing":      "drop"
      },
      "diagnostic": {
        "feature_importance":  true,
        "granger_causality":   true
      },
      "inferential": {
        "hypothesis_tests": ["t_test", "chi_square"]
      },
      "predictive": {
        "forecast_horizon":     48,
        "anomaly_detection":    true,
        "maintenance_model":    "trend_threshold",
        "classification_target":"Anomalie"
      },
      "prescriptive": {
        "optimization": true,
        "alert_thresholds": {
          "Aussen-Temperatur": {"min": -10, "max": 50}
        }
      },
      "patterns": {
        "clustering_n_clusters": 3,
        "sequence_window":       10
      },
      "timeseries": {
        "stl_period": 120,
        "acf_lags":   60
      },
      "anomaly_extended": {
        "zscore_threshold":  3.0,
        "cusum_threshold":   5.0,
        "ruptures_n_breaks": 5
      },
      "correlation_advanced": {
        "vif_threshold": 10.0
      },
      "regression_models": {
        "cv_folds":       5,
        "run_gridsearch": true
      }
    }
  }
}
